<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>net9.0</TargetFramework>
        <RootNamespace>$(MSBuildProjectName)</RootNamespace>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    </PropertyGroup>

    <ItemGroup>
        <Reference Include="TerrariaServer" HintPath="..\TShockServer\bin\TerrariaServer.dll" />
        <Reference Include="TShockAPI" HintPath="..\TShockServer\bin\TShockAPI.dll" />
        <Reference Include="OTAPI" HintPath="..\TShockServer\bin\OTAPI.dll" />
        <Reference Include="OTAPI.Runtime" HintPath="..\TShockServer\bin\OTAPI.Runtime.dll" />
        <Reference Include="HttpServer" HintPath="..\TShockServer\bin\HttpServer.dll" />
    </ItemGroup>

</Project>
